rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - subscription: string (required, ['free', 'pro'])
    //   - decisionsCount: number (optional)
    //   - lastDecisionDate: string (optional)
    //
    // Collection: decisions
    // Document ID: {decisionId}
    // Fields:
    //   - uid: string (required, owner UID)
    //   - title: string (required)
    //   - description: string (optional)
    //   - mode: string (required, ['analyst', 'money', 'life', 'brutal'])
    //   - inputs: map (optional)
    //   - analysis: map (optional)
    //   - createdAt: timestamp (required)
    //   - isHelpful: boolean (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "maxzuraj@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'subscription']) &&
        data.uid is string &&
        data.email is string &&
        data.subscription in ['free', 'pro'];
    }

    function isValidDecision(data) {
      return data.keys().hasAll(['uid', 'title', 'mode', 'createdAt']) &&
        data.uid is string &&
        data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
        data.mode in ['analyst', 'money', 'life', 'brutal'] &&
        data.createdAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.subscription == 'free';
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.subscription == resource.data.subscription) || isAdmin();
    }

    match /decisions/{decisionId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidDecision(request.resource.data);
      allow update: if isDocOwner() && isValidDecision(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
